  "shortcuts": [
    {
      "name": "New Post",
      "short_name": "Post",
      "description": "Create a new post",
      "url": "/?action=post",
      "icons": [
        {
          "src": "/icons/post-shortcut.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Truth Seeker",
      "short_name": "Truth",
      "description": "Verify facts and claims",
      "url": "/truthseeker",
      "icons": [
        {
          "src": "/icons/truth-shortcut.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Messages",
      "short_name": "Chat",
      "description": "View your messages",
      "url": "/messages",
      "icons": [
        {
          "src": "/icons/messages-shortcut.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Notifications",
      "short_name": "Alerts",
      "description": "View your notifications",
      "url": "/notifications",
      "icons": [
        {
          "src": "/icons/notifications-shortcut.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Ravensight",
      "short_name": "Studio",
      "description": "Record and upload videos",
      "url": "/ravensight",
      "icons": [
        {
          "src": "/icons/ravensight-shortcut.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Planner",
      "short_name": "Tasks",
      "description": "Manage your goals and tasks",
      "url": "/planner",
      "icons": [
        {
          "src": "/icons/planner-shortcut.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "display_override": [ "window-controls-overlay", "standalone" ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": [ "focus-existing", "auto" ]
  },
  "note_taking": {
    "new_note_url": "/planner"
  },
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "media",
          "accept": [ "image/*", "video/*", "audio/*" ]
        }
      ]
    }
  },
  "file_handlers": [
    {
      "action": "/upload",
      "accept": {
        "image/*": [ ".jpg", ".jpeg", ".png", ".gif", ".webp" ],
        "video/*": [ ".mp4", ".webm", ".mov", ".avi" ],
        "audio/*": [ ".mp3", ".wav", ".ogg", ".m4a" ],
        "application/pdf": [ ".pdf" ],
        "text/plain": [ ".txt" ]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+wiseraven",
      "url": "/?claim=%s"
    }
  ],
  "url_handlers": [
    {
      "origin": "https://wiseravenshare.com",
      "url": "/"
    }
  ]
}
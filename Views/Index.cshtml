        border-radius: 10px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--border-color);
        margin-bottom: 12px;
        overflow: hidden;
    }

    .social-feed-card:last-child {
        margin-bottom: 0;
    }

    .social-feed-title {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 10px;
        font-weight: 600;
        color: var(--text-color);
    }

    .social-feed-frame-wrap {
        border-radius: 8px;
        overflow: hidden;
        background: #fff;
    }

    .social-feed-iframe {
        width: 100%;
        height: 430px;
        border: 0;
    }

    .social-embed-block {
        width: 100% !important;
        min-width: 0 !important;
